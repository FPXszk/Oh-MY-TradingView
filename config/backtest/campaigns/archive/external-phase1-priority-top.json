{
  "id": "external-phase1-priority-top",
  "name": "External Phase 1 — Priority Top Presets (Experiment Gating)",
  "description": "Phase 1 bounded campaign for experiment gating. Uses the top 5 donchian presets from the cross-market campaign against the cross-market 100 universe. Gated summary and ranked candidates are emitted as additive artifacts.",
  "universe": "long-run-cross-market-100",
  "preset_ids": [
    "donchian-55-20-rsp-filter-rsi14-regime-55-hard-stop-8pct-theme-deep-pullback-tight",
    "donchian-50-20-rsp-filter-rsi14-regime-60-hard-stop-8pct-theme-deep-pullback-strict-entry-early",
    "donchian-55-20-rsp-filter-rsi14-regime-50-hard-stop-8pct-theme-breadth-quality-balanced-wide",
    "donchian-50-20-rsp-filter-rsi14-regime-55-hard-stop-8pct-theme-deep-pullback-tight-entry-early",
    "donchian-55-18-rsp-filter-rsi14-regime-55-hard-stop-8pct-theme-deep-pullback-tight-exit-tight"
  ],
  "date_override": {
    "from": "2000-01-01",
    "to": "2099-12-31"
  },
  "phases": {
    "smoke": {
      "symbol_count": 10
    },
    "pilot": {
      "symbol_count": 25
    },
    "full": {
      "symbol_count": 100
    }
  },
  "experiment_gating": {
    "enabled": true,
    "thresholds": {
      "promote": {
        "min_profit_factor": 1.2,
        "min_closed_trades": 10,
        "min_percent_profitable": 35
      },
      "reject": {
        "max_profit_factor": 0.8,
        "max_drawdown_pct": 80
      }
    }
  },
  "execution": {
    "worker_ports": [9223],
    "checkpoint_every": 10,
    "cooldown_ms": 1000,
    "max_consecutive_failures": 5,
    "max_rerun_passes": 2
  },
  "notes": "Phase 1 experiment gating campaign. Emits gated-summary.json and ranked-candidates.json as additive artifacts alongside existing final-results.json / recovered-summary.json."
}
