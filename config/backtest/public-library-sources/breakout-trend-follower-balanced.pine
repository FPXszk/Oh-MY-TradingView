//@version=6
strategy("Breakout Trend Follower Balanced", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

startTime = input.time(1420070400000, "Start Time")
finishTime = input.time(1767225540000, "End Time")

useMaFilter = input.bool(true, "Use MA for Filtering?")
maType = input.string("SMA", "MA Type For Filtering", options=["EMA", "SMA"])
maLength = input.int(50, "MA Period for Filtering", minval=1)
stopBufferPct = input.float(0.0, "Stop Buffer %", minval=0.0, step=0.1)
entryBufferPct = input.float(0.0, "Entry Buffer %", minval=0.0, step=0.1)
pivotLeft = input.int(3, "Pivot Left Bars", minval=1)
pivotRight = input.int(3, "Pivot Right Bars", minval=1)

maValue = maType == "EMA" ? ta.ema(close, maLength) : ta.sma(close, maLength)
plot(maValue, "Trend Filter MA", color=color.new(color.green, 40), linewidth=2)

rawPivotHigh = ta.pivothigh(high, pivotLeft, pivotRight)
rawPivotLow = ta.pivotlow(low, pivotLeft, pivotRight)

buyLevel = ta.valuewhen(not na(rawPivotHigh), high[pivotRight], 0)
stopLevel = ta.valuewhen(not na(rawPivotLow), low[pivotRight], 0)

plot(buyLevel, "Buy Level", color=color.new(color.blue, 35), linewidth=1, trackprice=true)
plot(stopLevel, "Stop Level", color=color.new(color.orange, 35), linewidth=1, trackprice=true)

entryThreshold = na(buyLevel) ? na : buyLevel * (1 + entryBufferPct / 100.0)
stopThreshold = na(stopLevel) ? na : stopLevel * (1 - stopBufferPct / 100.0)
inDateRange = time >= startTime and time <= finishTime
filterPass = not useMaFilter or close > maValue

buySignal = inDateRange and filterPass and not na(entryThreshold) and high > entryThreshold
sellSignal = strategy.position_size > 0 and not na(stopThreshold) and low < stopThreshold

if buySignal and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0 and not na(stopThreshold)
    strategy.exit("Swing Low Stop", "Long", stop=stopThreshold)

if sellSignal
    strategy.close("Long", comment="Swing low breach")

plotshape(buySignal and strategy.position_size <= 0, title="Buy", style=shape.triangleup, location=location.belowbar, color=color.new(#1E90FF, 0), size=size.tiny, text="Buy")
plotshape(sellSignal, title="Sell", style=shape.triangledown, location=location.abovebar, color=color.new(#EE82EE, 0), size=size.tiny, text="Sell")
