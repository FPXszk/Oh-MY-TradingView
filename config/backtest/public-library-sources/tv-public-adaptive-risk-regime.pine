//@version=6
strategy("Adaptive Risk Regime Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)
fast = ta.ema(close, 20)
slow = ta.ema(close, 100)
volFast = ta.atr(14)
volSlow = ta.sma(volFast, 50)
riskOn = volFast < volSlow
if ta.crossover(fast, slow) and riskOn
    strategy.entry("Long", strategy.long)
if ta.crossunder(fast, slow) or not riskOn
    strategy.close("Long")
plot(fast, "Fast", color=color.green)
plot(slow, "Slow", color=color.red)
