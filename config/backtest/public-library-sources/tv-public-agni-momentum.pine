//@version=6
strategy("AGNI MOMENTUM - Ultimate Swing Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
macdLine = ta.ema(close, 12) - ta.ema(close, 26)
signalLine = ta.ema(macdLine, 9)
trend = ema20 > ema50
if ta.crossover(macdLine, signalLine) and trend
    strategy.entry("Long", strategy.long)
if ta.crossunder(macdLine, signalLine)
    strategy.close("Long")
plot(ema20, "EMA 20", color=color.green)
plot(ema50, "EMA 50", color=color.orange)
