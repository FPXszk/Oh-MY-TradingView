//@version=6
strategy("KDJ L2: Advanced Momentum & Reversal Strategy", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=100)
kLength = input.int(18, "Length", minval=1)
buyLevel = input.float(20.0, "BuyAlertLimit")
sellLevel = input.float(80.0, "SellAlertLimit")
ll = ta.lowest(low, kLength)
hh = ta.highest(high, kLength)
rsv = hh == ll ? 50.0 : 100.0 * (close - ll) / (hh - ll)
k = ta.ema(rsv, 3)
d = ta.ema(k, 3)
j = 3.0 * k - 2.0 * d
if ta.crossover(j, buyLevel)
    strategy.entry("Long", strategy.long)
exitSignal = ta.crossunder(j, sellLevel) or (ta.crossunder(j, k) and j > 50)
if exitSignal
    strategy.close("Long")
plot(j, "J", color=color.fuchsia)
plot(k, "K", color=color.aqua)
plot(d, "D", color=color.orange)
