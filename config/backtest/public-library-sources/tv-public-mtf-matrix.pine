//@version=6
strategy("MTF Matrix Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)
htf = input.timeframe("240", "Higher TF")
htfFast = request.security(syminfo.tickerid, htf, ta.ema(close, 20))
htfSlow = request.security(syminfo.tickerid, htf, ta.ema(close, 50))
ltfFast = ta.ema(close, 10)
ltfSlow = ta.ema(close, 30)
if ta.crossover(ltfFast, ltfSlow) and htfFast > htfSlow
    strategy.entry("Long", strategy.long)
if ta.crossunder(ltfFast, ltfSlow) and htfFast < htfSlow
    strategy.entry("Short", strategy.short)
if ta.crossunder(close, ltfSlow)
    strategy.close("Long")
if ta.crossover(close, ltfSlow)
    strategy.close("Short")
plot(ltfFast, "LTF Fast", color=color.green)
plot(ltfSlow, "LTF Slow", color=color.orange)
