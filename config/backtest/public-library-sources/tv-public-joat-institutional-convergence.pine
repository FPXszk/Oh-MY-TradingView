//@version=6
strategy("JOAT Institutional Convergence [JOAT]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)
ema34 = ta.ema(close, 34)
ema89 = ta.ema(close, 89)
vwapValue = ta.vwap(hlc3)
rsiValue = ta.rsi(close, 14)
bull = close > ema34 and ema34 > ema89 and close > vwapValue and rsiValue > 55
bear = close < ema34 and ema34 < ema89 and close < vwapValue and rsiValue < 45
if bull and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
if bear and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
if ta.crossunder(close, ema34)
    strategy.close("Long")
if ta.crossover(close, ema34)
    strategy.close("Short")
plot(ema34, "EMA 34", color=color.yellow)
plot(ema89, "EMA 89", color=color.blue)
plot(vwapValue, "VWAP", color=color.purple)
